generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  income
  expense
}

model Church {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  // Unicidade parcial (UNIQUE WHERE deleted_at IS NULL) criada via SQL manual
  // na migration init — Prisma não expressa índice único parcial no schema.
  email        String
  password     String
  phone        String?
  cnpj         String?
  denomination String?
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  members             Member[]
  ministries          Ministry[]
  categories          Category[]
  transactions        Transaction[]
  reports             Report[]
  passwordResetTokens PasswordResetToken[]

  @@map("church")
}

model Member {
  id          String    @id @default(uuid()) @db.Uuid
  churchId    String    @map("church_id") @db.Uuid
  name        String
  birthDate   DateTime? @map("birth_date") @db.Date
  baptismDate DateTime? @map("baptism_date") @db.Date
  email       String?
  phone       String?
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  church         Church        @relation(fields: [churchId], references: [id])
  responsibleFor Ministry[]
  transactions   Transaction[]

  @@index([churchId])
  @@map("church_members")
}

model Ministry {
  id            String    @id @default(uuid()) @db.Uuid
  churchId      String    @map("church_id") @db.Uuid
  responsibleId String?   @map("responsible_id") @db.Uuid
  name          String
  description   String?
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  church       Church        @relation(fields: [churchId], references: [id])
  responsible  Member?       @relation(fields: [responsibleId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([churchId])
  @@map("church_ministries")
}

model Category {
  id          String          @id @default(uuid()) @db.Uuid
  churchId    String          @map("church_id") @db.Uuid
  name        String
  description String?
  // Imutável após a criação — regra aplicada no service, não no banco
  type        TransactionType
  color       String
  deletedAt   DateTime?       @map("deleted_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  church       Church        @relation(fields: [churchId], references: [id])
  transactions Transaction[]

  @@index([churchId])
  @@map("church_transaction_categories")
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  churchId    String          @map("church_id") @db.Uuid
  categoryId  String          @map("category_id") @db.Uuid
  // Tipo próprio da transação (não derivado da categoria); o service valida
  // que a categoria escolhida tem o mesmo type.
  type        TransactionType
  // Armazenado com sinal: positivo se income, negativo se expense.
  value       Decimal         @db.Decimal(12, 2)
  date        DateTime        @db.Date
  description String?
  memberId    String?         @map("member_id") @db.Uuid
  ministryId  String?         @map("ministry_id") @db.Uuid
  deletedAt   DateTime?       @map("deleted_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  church   Church    @relation(fields: [churchId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  member   Member?   @relation(fields: [memberId], references: [id], onDelete: SetNull)
  ministry Ministry? @relation(fields: [ministryId], references: [id], onDelete: SetNull)

  @@index([churchId, date])
  @@map("transaction")
}

model Report {
  id          String   @id @default(uuid()) @db.Uuid
  churchId    String   @map("church_id") @db.Uuid
  // Chave interna no bucket S3; nunca exposta diretamente ao cliente
  filePath    String   @map("file_path")
  generatedAt DateTime @default(now()) @map("generated_at")

  church Church @relation(fields: [churchId], references: [id])

  @@index([churchId])
  @@map("church_reports")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  churchId  String    @map("church_id") @db.Uuid
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  church Church @relation(fields: [churchId], references: [id])

  @@index([churchId])
  @@map("password_reset_token")
}
