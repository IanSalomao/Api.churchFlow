# App
PORT=3000

# Postgres (usados pelo docker-compose para criar o banco)
POSTGRES_USER=miyrah
POSTGRES_PASSWORD=miyrah
POSTGRES_DB=miyrah

# Prisma — host "postgres" é o nome do serviço no docker-compose.
# Se for rodar a API/Prisma direto no host, troque "postgres" por "localhost".
DATABASE_URL=postgresql://miyrah:miyrah@postgres:5432/miyrah?schema=public

# Auth
JWT_SECRET=troque-por-um-segredo-forte
JWT_EXPIRATION_DEFAULT=24h
JWT_EXPIRATION_REMEMBER_ME=30d

# Front-end (usado no link do e-mail de recuperação de senha)
FRONTEND_URL=http://localhost:5173

# E-mail (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Remetente dos e-mails; o default (sandbox do Resend) funciona sem domínio verificado
MAIL_FROM=Miyrah <onboarding@resend.dev>

# Storage S3-compatible (MinIO local)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=miyrah
S3_SECRET_KEY=miyrah-secret
S3_BUCKET=miyrah-reports
